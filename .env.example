DISCORD_TOKEN=
BOT_PREFIX=!bot
BOT_NAME=Juan
APPLICATION_ID=
GUILD_ID= # Optional: Set to your server ID to sync slash commands instantly for testing


# Jarvis Gemma GGUF via llama-server
LLM_URL=http://127.0.0.1:8080/v1/chat/completions
LLM_HEALTH_URL=http://127.0.0.1:8080/health
LLM_MODEL=gemma4-agentic-v2-q4
JARVIS_DIR=/Users/jimmypark/Applications/Jarvis

LLM_TIMEOUT=300
LLM_RETRY_TIMEOUT=180
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.8
LLM_TOP_P=0.9
LLM_KEEPALIVE_INTERVAL=180
CHANNEL_CONTEXT_LIMIT=10
MEMORY_CONTEXT_LIMIT=15
MAX_MESSAGE_CHARS=200
MAX_PROMPT_CHARS=6000
MAX_REPLY_CHARS=1900
MAX_REPLY_WORDS=0

# Web search (optional — DDG works without keys; pulls from Jarvis .env if unset)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
SEARCH_MAX_RESULTS=5

# Chance Juan spontaneously adds a meme/GIF to a reply (0.0 - 1.0)
VISUAL_REPLY_CHANCE=0.35